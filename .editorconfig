# EditorConfig — https://editorconfig.org
# Підтримується VS Code, WebStorm, Vim, Emacs та іншими редакторами.
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
# Markdown: зберігати trailing whitespace (подвійний пробіл = line break)
trim_trailing_whitespace = false

[*.{json,yml,yaml}]
indent_size = 2

[*.env*]
# .env файли — не змінювати автоматично
insert_final_newline = false
